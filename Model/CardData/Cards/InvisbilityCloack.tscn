[node name="Control" instance=ExtResource("1_yt8fi")]
cardName = "Invisibility Cloak"
cardSprite = ExtResource("2_0y57k")
cardDescription = "Wrap yourself in a carefully positioned array of Psyche's solar electric thrusters, ionizing xenon gas around you to create a shimmering plasma field. Does it actually make you invisible? No. But it does make you look like a ghostly space wizard."
cardBehavior = Array[Resource]([SubResource("Resource_4qvaf")])
cardUseHeader = "Despite remaining visible, your new wizardly appearance boosts your confidence- and your speed!"
extraInfoHeaderString = "Hall-effect thrusters"
extraInfoBodyString = "As a part of the Psyche mission, Psyche's Hall thrusters are the first to be used beyond lunar orbit, potentially pioneering its use in future deep space missions. The super-efficient thrusters turn xenon gas into xenon ions which, when accelerated out of the thruster, create the thrust that propels the spacecraft."
hasExtraInfo = true
extraInfoLink = "https://www.jpl.nasa.gov/images/pia24030-psyches-hall-thruster/"

