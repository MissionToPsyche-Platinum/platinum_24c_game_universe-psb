cardName = "Frisbee of Doom"
cardDescription = "Originally designed for deep-space communication, this high-gain X-band antenna also happens to be perfectly shaped for high-velocity disc throws. Whether you need to send a signal or send something flying, it's got range."
cardBehavior = Array[Resource]([SubResource("Resource_8exdr")])
cardUseHeader = "The disc soars off of your antenna and into the intruders, thrusting them out into space!"
extraInfoHeaderString = "High-gain X-band antenna"
extraInfoBodyString = "Psyche's X-band radio telecommunications system will be used to measure the Psyche asteroid's gravity field to high precision. Combined with topography data also gathered during the mission, this will give scientists valuable insight into Psyche's interior structure."
