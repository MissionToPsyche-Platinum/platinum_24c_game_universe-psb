[node name="Control" instance=ExtResource("1_f1ttt")]
cardName = "Planetary Swing"
cardDescription = "Psyche harnesses the gravitational pull of nearby planets to take out space intruders or get around unexpected obstacles. Need to speed up or throw off a space pirate? Just slingshot around for some extra oomph."
cardBehavior = Array[Resource]([SubResource("Resource_hvi5b")])
cardUseHeader = "Using the power of gravity assist, Psyche catapults around a nearby planet and straight away from the threat!"
extraInfoHeaderString = "Mars gravity assist"
extraInfoBodyString = "In May 2026, Psyche mostly turned off its thrusters and flew relatively close (between 1,900 to 2,700 miles or 3,000 to 4,400 kilometers) above Mars to harness the planet's gravity, increasing its speed and changing direction using minimal propellant.  "
hasExtraInfo = true
extraInfoLink = "https://www.jpl.nasa.gov/press-kits/psyche/mission/"

