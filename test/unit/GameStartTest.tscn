[sub_resource type="GDScript" id="GDScript_01l7t"]
script/source = "extends GutTest

func test_game_starts_successfully():
	# Load the main game scene
	var main_scene_path = \"res://scenes/main_game.tscn\" # Adjust this path to your main scene
	var main_scene = load(main_scene_path)
	assert_not_null(main_scene, \"Main scene should not be null\")

	# Instantiate the main scene
	var main_instance = main_scene.instantiate()
	assert_not_null(main_instance, \"Main scene instance should not be null\")

	# Add the main scene to the current tree (for testing purposes)
	get_tree().get_root().add_child(main_instance)

	# Clean up after the test (remove the instantiated scene)
	main_instance.queue_free()
"

